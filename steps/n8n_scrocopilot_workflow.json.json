    {
      "parameters": {
        "functionCode": "const data = items[0].json;\nconst text = (data.text || '');\nconst urlRegex = /https?:\\/\\/[\\w\\-\\.\\/?&=:%#~+]+/gi;\nconst phoneRegex = /(?:\\+65|65|0)?[89]\\d{7}/g;\nconst urls = text.match(urlRegex) || [];\nconst phones = text.match(phoneRegex) || [];\nconst otpRegex = /\\b(otp|one[- ]time password|one time pwd|verification code)\\b/i;\nconst contains_otp_request = otpRegex.test(text);\nconst media_type = data.mediaId ? 'image' : 'none';\nreturn [{ json: { ...data, urls, phones, contains_otp_request, media_type } }];"
      },
      "name": "Function - Extract",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        760,
        200
