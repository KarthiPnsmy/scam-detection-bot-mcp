    {
      "parameters": {
        "authentication": "headerAuth",
        "requestMethod": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "responseFormat": "json",
        "jsonParameters": true,
        "options": {},
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{$env.OPENAI_API_KEY}}"
        },
        "body": {
          "model": "gpt-4o-mini",
          "messages": [
            {
              "role": "system",
              "content": "You are a tool-selection agent. Given the inbound message and metadata, return ONLY valid JSON with fields: tools (subset of [\\\"follow_redirects\\\",\\\"whois\\\",\\\"urlscan\\\",\\\"virustotal\\\",\\\"ocr\\\",\\\"screenshot\\\"]), priority (low|normal|high), reason (1-2 sentences). Prefer lightweight checks unless the message indicates high risk."
            },
            {
              "role": "user",
              "content": " { \"message\": \"{{$json[\\\"text\\\"]}}\", \"urls\": {{$json[\\\"urls\\\"]}}, \"media_type\":\"{{$json[\\\"media_type\\\"]}}\", \"contains_otp_request\": {{$json[\\\"contains_otp_request\\\"]}} }"
            }
          ],
          "temperature": 0.0,
          "max_tokens": 220
        }
      },
      "name": "HTTP Request - ToolSelector (OpenAI)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        1100,
        200
      ]
    },
    {
      "parameters": {
        "functionCode": "// Parse the OpenAI tool selector response and output tools, priority\nconst body = items[0].json;\nlet content = null;\ntry {\n  // content may be in choices[0].message.content\n  if (body.choices && body.choices[0] && body.choices[0].message && body.choices[0].message.content) {\n    content = body.choices[0].message.content;\n  } else if (body.choices && body.choices[0] && body.choices[0].text) {\n    content = body.choices[0].text;\n  }\n  if (!content) throw new Error('No content from OpenAI');\n  // strip ``` blocks and whitespace\n  content = content.replace(/```json\\s*/i, '').replace(/```/g, '').trim();\n  const parsed = JSON.parse(content);\n  return [{ json: { tools: parsed.tools || [], priority: parsed.priority || 'normal', reason: parsed.reason || '' } }];\n} catch (err) {\n  // fallback: no tools\n  return [{ json: { tools: [], priority: 'low', reason: 'Could not parse tool selector response' } }];\n}"
      },
      "name": "Function - Parse ToolSelector",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
