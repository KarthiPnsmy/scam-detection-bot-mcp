        "functionCode": "// Parse final verdict JSON from OpenAI\nconst body = items[0].json;\nlet content = null;\ntry {\n  if (body.choices && body.choices[0] && body.choices[0].message && body.choices[0].message.content) {\n    content = body.choices[0].message.content;\n  } else if (body.choices && body.choices[0] && body.choices[0].text) {\n    content = body.choices[0].text;\n  }\n  if (!content) throw new Error('No content from OpenAI');\n  content = content.replace(/```json\\s*/i, '').replace(/```/g, '').trim();\n  const parsed = JSON.parse(content);\n  return [{ json: { verdict: parsed.verdict || 'Suspicious', confidence: parsed.confidence || 40, short_reply: parsed.short_reply || 'We could not determine; please avoid clicking the link.' } }];\n} catch (err) {\n  return [{ json: { verdict: 'Suspicious', confidence: 40, short_reply: 'We could not determine safely; please avoid clicking links.' } }];\n}"
