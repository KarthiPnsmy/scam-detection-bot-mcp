        "functionCode": "// Verify callback secret provided either as header X-Callback-Secret or body.callback_secret\nconst headers = items[0].json.headers || {};\nconst body = items[0].json;\nconst headerSecret = (headers['x-callback-secret'] || headers['X-Callback-Secret'] || headers['x-callback-secret'.toLowerCase()]) || null;\nconst bodySecret = body.callback_secret || null;\nconst expected = process.env.CALLBACK_SECRET;\nif (expected && (headerSecret !== expected && bodySecret !== expected)) {\n  throw new Error('Invalid callback secret');\n}\nreturn items;"
