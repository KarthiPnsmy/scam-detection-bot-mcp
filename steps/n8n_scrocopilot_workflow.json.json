    {
      "parameters": {
        "functionCode": "// Compose evidence JSON for final verdict prompt\nconst data = items[0].json;\nconst results = items[0].json.results || items[0].json;\n// If Chroma returned items in previous node, they will be in $items[1]\nlet sources = [];\ntry {\n  if (items.length > 1 && items[1].json && items[1].json.result) {\n    // If Chroma returns in items[1]\n  }\n} catch(e){}\n// For simplicity assume the Chroma response is in items[1]\nif (items[1] && items[1].json && items[1].json.result) {\n  const res = items[1].json.result;\n  if (res && res[0] && res[0].documents) {\n    for (let i=0;i<res.length;i++){\n      const row = res[i];\n      if (row && row.metadatas && row.documents) {\n        for (let j=0;j<row.documents.length;j++){\n          sources.push({ id: (row.ids && row.ids[j]) || null, title: (row.metadatas[j] && row.metadatas[j].title) || null, text: row.documents[j], url: (row.metadatas[j] && row.metadatas[j].url) || null });\n        }\n      }\n    }\n  }\n}\nconst evidence = {\n  text: items[0].json.text || '',\n  urls: items[0].json.urls || [],\n  mcp_results: items[0].json.results || {},\n  sources\n};\nreturn [{ json: { evidence } }];"
      },
